# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Saathi
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Database ─────────────────────────────────────────────────────────────────
# Async URL (used by SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://saathi_user:saathi_pass@localhost:5432/saathi_db
# Sync URL (used by Alembic)
SYNC_DATABASE_URL=postgresql+psycopg2://saathi_user:saathi_pass@localhost:5432/saathi_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Redis (optional) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# ─── AI Engine ────────────────────────────────────────────────────────────────
AI_ENGINE_URL=http://localhost:8001
