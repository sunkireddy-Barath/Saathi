APP_ENV=development
SECRET_KEY=generate-a-secure-secret-key-here
# Supabase PostgreSQL connection strings (Replace with your Supabase Transaction Pooler URL)
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true
AI_ENGINE_URL=http://localhost:8001
